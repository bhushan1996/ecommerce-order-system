              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "orders"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING",
                  "description": "Filter by status: PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED"
